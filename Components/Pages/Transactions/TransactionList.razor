@page "/transactions"
@using InvestTracker.Models
@using InvestTracker.Models.Enums
@using InvestTracker.Services.Interfaces
@using InvestTracker.Services
@inject ITransactionService TransactionService
@inject IAssetService AssetService
@inject AuthState AuthState
@inject NavigationManager NavigationManager

<PageTitle>Transactions — InvestTracker</PageTitle>

<h3>💸 Historique des Transactions</h3>

<!-- Bouton Nouvelle Transaction -->
<a href="/transactions/edit" class="btn btn-success mb-3">
    + Nouvelle Transaction
</a>

<!-- Filtres -->
<div class="row mb-3">
    <div class="col-md-3">
        <select class="form-select" @onchange="OnTypeFilterChanged">
            <option value="">-- Tous types --</option>
            <option value="Buy">Achat</option>
            <option value="Sell">Vente</option>
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" @onchange="OnAssetFilterChanged">
            <option value="0">-- Tous les actifs --</option>
            @if (assets != null)
            {
                @foreach (var asset in assets)
                {
                    <option value="@asset.Id">@asset.Symbol - @asset.Name</option>
                }
            }
        </select>
    </div>
</div>

<!-- Tableau -->
@if (transactions == null)
{
    <p>Chargement...</p>
}
else if (!transactions.Any())
{
    <div class="alert alert-info">Aucune transaction trouvée.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>Actif</th>
                <th>Type</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Total</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tx in transactions)
            {
                <tr>
                    <td>@tx.Date.ToString("dd/MM/yyyy")</td>
                    <td><strong>@tx.Asset?.Symbol</strong></td>
                    <td>
                        @if (tx.Type == TransactionType.Buy)
                        { <span class="badge bg-success">↑ Achat</span> }
                        else
                        { <span class="badge bg-danger">↓ Vente</span> }
                    </td>
                    <td>@tx.Quantity</td>
                    <td>@tx.PriceAtTransaction.ToString("N2") €</td>
                    <td><strong>@((tx.Quantity * tx.PriceAtTransaction).ToString("N2")) €</strong></td>
                    <td>@tx.Notes</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => AskDelete(tx.Id, tx.Asset?.Symbol, tx.Quantity)">
                            🗑️
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">Total : @transactions.Count transaction(s)</p>
}

<!-- ConfirmDialog : affiché seulement quand showConfirm = true -->
<ConfirmDialog
    IsVisible="showConfirm"
    Message="@confirmMessage"
    OnConfirm="ConfirmDelete"
    OnCancel="CancelDelete" />

@code {
    private List<Transaction>? transactions;
    private List<Asset>? assets;

    private int currentUserId => AuthState.CurrentUser!.Id;

    // ── Variables pour la confirmation ──
    private bool showConfirm = false;
    private int  pendingDeleteId;
    private string confirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        assets = await AssetService.GetAssetsAsync();
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        transactions = await TransactionService
            .GetTransactionsAsync(currentUserId);
    }

    private async Task OnTypeFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrEmpty(value))
            await LoadTransactions();
        else
        {
            var type = Enum.Parse<TransactionType>(value);
            transactions = await TransactionService
                .GetTransactionsByTypeAsync(currentUserId, type);
        }
    }

    private async Task OnAssetFilterChanged(ChangeEventArgs e)
    {
        var value = int.Parse(e.Value?.ToString() ?? "0");
        if (value == 0)
            await LoadTransactions();
        else
            transactions = await TransactionService
                .GetTransactionsByAssetAsync(currentUserId, value);
    }

    // Étape 1 : clic sur 🗑️ → ouvrir la boîte de confirmation
    private void AskDelete(int id, string? symbol, decimal qty)
    {
        pendingDeleteId = id;
        confirmMessage  =
            $"Supprimer la transaction de {qty} {symbol ?? "actif"} ? " +
            $"Le portefeuille sera mis à jour automatiquement.";
        showConfirm = true;
    }

    // Étape 2a : l'utilisateur clique « Supprimer »
    private async Task ConfirmDelete()
    {
        showConfirm = false;
        await TransactionService.DeleteTransactionAsync(pendingDeleteId);
        await LoadTransactions();
    }

    // Étape 2b : l'utilisateur clique « Annuler »
    private void CancelDelete()
    {
        showConfirm     = false;
        pendingDeleteId = 0;
    }
}
