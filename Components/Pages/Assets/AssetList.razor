@page "/assets"
@using InvestTracker.Models
@using InvestTracker.Models.Enums
@using InvestTracker.Services.Interfaces
@inject IAssetService AssetService

<h3>📈 Gestion des Actifs</h3>

<a href="/assets/edit" class="btn btn-success mb-3">
    + Nouvel Actif
</a>

<!-- Filtres -->
<div class="row mb-3">
    <div class="col-md-4">
        <input type="text"
               class="form-control"
               placeholder="Rechercher par nom ou symbole..."
               @bind="searchKeyword"
               @bind:event="oninput" />
    </div>
    <div class="col-md-3">
        <select class="form-select" @onchange="OnTypeFilterChanged">
            <option value="">-- Tous les types --</option>
            <option value="Stock">Stock</option>
            <option value="Crypto">Crypto</option>
        </select>
    </div>
</div>

<!-- Confirmation suppression -->
@if (showConfirm)
{
    <div class="alert alert-danger d-flex 
        justify-content-between align-items-center">
        <span>⚠️ @confirmMessage</span>
        <div>
<button class="btn btn-danger btn-sm me-2"
        @onclick="ConfirmDelete">
    ✅ Confirmer
</button>

<button class="btn btn-secondary btn-sm"
        @onclick="CancelDelete">
    ❌ Annuler
</button>
        </div>
    </div>
}

<!-- Tableau -->
@if (filteredAssets == null)
{
    <p>Chargement...</p>
}
else if (!filteredAssets.Any())
{
    <div class="alert alert-info">Aucun actif trouvé.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Symbole</th>
                <th>Nom</th>
                <th>Type</th>
                <th>Prix Actuel</th>
                <th>Dernière MAJ</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var asset in filteredAssets)
            {
                <tr>
                    <td><strong>@asset.Symbol</strong></td>
                    <td>@asset.Name</td>
                    <td>
                        @if (asset.Type == AssetType.Crypto)
                        {
                            <span class="badge bg-warning text-dark">
                                Crypto
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-primary">
                                Stock
                            </span>
                        }
                    </td>
                    <td>
                        <strong>
                            @asset.CurrentPrice.ToString("N2") €
                        </strong>
                    </td>
                    <td>
                        @asset.LastUpdated.ToString("dd/MM/yyyy HH:mm")
                    </td>
                    <td>
                        <a href="/assets/edit/@asset.Id"
                           class="btn btn-sm btn-outline-primary me-1">
                            ✏️ Modifier
                        </a>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => AskDelete(asset.Id, asset.Name)">
                            🗑️ Supprimer
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">Total : @filteredAssets.Count actif(s)</p>
}

@code {
    private List<Asset>? allAssets;
    private List<Asset>? filteredAssets;
    private string _searchKeyword = string.Empty;
    private string searchKeyword
    {
        get => _searchKeyword;
        set { _searchKeyword = value; ApplyFilters(); }
    }
    private string typeFilter = string.Empty;

    // Confirmation suppression
    private bool showConfirm = false;
    private string confirmMessage = string.Empty;
    private int assetToDeleteId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssets();
    }

    private async Task LoadAssets()
    {
        allAssets = await AssetService.GetAssetsAsync();
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        if (allAssets == null) return;
        filteredAssets = allAssets;

        if (!string.IsNullOrWhiteSpace(searchKeyword))
        {
            filteredAssets = filteredAssets
                .Where(a =>
                    a.Name.Contains(searchKeyword,
                        StringComparison.OrdinalIgnoreCase)
                    || a.Symbol.Contains(searchKeyword,
                        StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        if (!string.IsNullOrWhiteSpace(typeFilter))
        {
            var type = Enum.Parse<AssetType>(typeFilter);
            filteredAssets = filteredAssets
                .Where(a => a.Type == type)
                .ToList();
        }
    }

    private void OnTypeFilterChanged(ChangeEventArgs e)
    {
        typeFilter = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    // Étape 1 : afficher la confirmation inline
    private void AskDelete(int id, string name)
    {
        assetToDeleteId = id;
        confirmMessage = $"Supprimer l'actif \"{name}\" ?";
        showConfirm = true;
    }

    // Étape 2 : confirmer
    private async Task ConfirmDelete()
    {
        await AssetService.DeleteAssetAsync(assetToDeleteId);
        showConfirm = false;
        assetToDeleteId = 0;
        await LoadAssets();
    }

    // Étape 2 bis : annuler
    private void CancelDelete()
    {
        showConfirm = false;
        assetToDeleteId = 0;
    }
}