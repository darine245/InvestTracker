@page "/portfolio"
@rendermode InteractiveServer 
@using InvestTracker.Models
@using InvestTracker.Services.Interfaces
@inject IPortfolioService PortfolioService
@inject IUserService UserService
@inject AuthState AuthState
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Portefeuille — InvestTracker</PageTitle>

@if (lines == null)
{
    <p>Chargement...</p>
}
else
{
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>💼 Mon Portefeuille</h3>
        <span class="text-muted small">👤 @AuthState.CurrentUser?.FullName</span>

    </div>
    <!-- KPIs -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h6 class="card-title">Valeur Totale</h6>
                    <h4>@totalValue.ToString("N2") €</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white
                @(gainLoss >= 0 ? "bg-success" : "bg-danger")">
                <div class="card-body">
                    <h6 class="card-title">Gain / Perte</h6>
                    <h4>
                        @(gainLoss >= 0 ? "+" : "")
                        @gainLoss.ToString("N2") €
                    </h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white
                @(gainLossPercent >= 0 ? "bg-success" : "bg-danger")">
                <div class="card-body">
                    <h6 class="card-title">Performance</h6>
                    <h4>
                        @(gainLossPercent >= 0 ? "+" : "")
                        @gainLossPercent.ToString("N2") %
                    </h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h6 class="card-title">Budget Disponible</h6>
                    <h4>@availableBudget.ToString("N2") €</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== GRAPHIQUES ===== -->
    @if (!string.IsNullOrEmpty(chartError))
    {
        <div class="alert alert-warning">
            ⚠️ @chartError
        </div>
    }
    @if (lines.Any())
    {
        <div class="row mb-4">

            <!-- Graphique 1 : Doughnut — répartition par type -->
            <div class="col-md-5">
                <div class="card h-100">
                    <div class="card-header fw-semibold">🥧 Répartition par Type</div>
                    <div class="card-body d-flex justify-content-center align-items-center">
                        <canvas id="doughnutChart" style="max-height:260px"></canvas>
                    </div>
                </div>
            </div>

            <!-- Graphique 2 : Barres — gain/perte par actif -->
            <div class="col-md-7">
                <div class="card h-100">
                    <div class="card-header fw-semibold">📊 Gain / Perte par Actif</div>
                    <div class="card-body">
                        <canvas id="barChart" style="max-height:260px"></canvas>
                    </div>
                </div>
            </div>

        </div>
    }


    <!-- Tableau des lignes -->
    @if (!lines.Any())
    {
        <div class="alert alert-info">
            Votre portefeuille est vide.
            <a href="/transactions/edit">Faire une transaction</a>
        </div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Actif</th>
                    <th>Type</th>
                    <th>Quantité</th>
                    <th>Prix Moyen Achat</th>
                    <th>Prix Actuel</th>
                    <th>Valeur Actuelle</th>
                    <th>Gain / Perte</th>
                    <th>Performance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in lines)
                {
                    var currentVal = line.Quantity
                        * line.Asset.CurrentPrice;
                    var cost = line.Quantity * line.AverageBuyPrice;
                    var gl = currentVal - cost;
                    var glPct = cost > 0
                        ? (gl / cost) * 100 : 0;

                    <tr>
                        <td>
                            <strong>@line.Asset.Symbol</strong>
                            <br/>
                            <small class="text-muted">
                                @line.Asset.Name
                            </small>
                        </td>
                        <td>@line.Asset.Type</td>
                        <td>@line.Quantity</td>
                        <td>
                            @line.AverageBuyPrice.ToString("N2") €
                        </td>
                        <td>
                            @line.Asset.CurrentPrice.ToString("N2") €
                        </td>
                        <td>
                            <strong>@currentVal.ToString("N2") €</strong>
                        </td>
                        <td class="@(gl >= 0
                            ? "text-success" : "text-danger")">
                            <strong>
                                @(gl >= 0 ? "+" : "")
                                @gl.ToString("N2") €
                            </strong>
                        </td>
                        <td class="@(glPct >= 0
                            ? "text-success" : "text-danger")">
                            @(glPct >= 0 ? "+" : "")
                            @glPct.ToString("N1") %
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<PortfolioLine>? lines;
    private decimal totalValue;
    private decimal gainLoss;
    private decimal gainLossPercent;
    private decimal availableBudget;
    private Dictionary<string, decimal> allocation = new();
    private string? chartError;
    private bool chartsRendered;
            // Lecture depuis AuthState — plus de hardcode
    private int currentUserId => AuthState.CurrentUser!.Id;
    

    protected override async Task OnInitializedAsync()
    {
         // Redirection si non connecté
        if (!AuthState.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        lines = await PortfolioService
            .GetPortfolioLinesAsync(currentUserId);
        totalValue = await PortfolioService
            .GetTotalValueAsync(currentUserId);
        gainLoss = await PortfolioService
            .GetTotalGainLossAsync(currentUserId);
        gainLossPercent = await PortfolioService
            .GetTotalGainLossPercentAsync(currentUserId);
        availableBudget = await UserService
            .GetAvailableBudgetAsync(currentUserId);
        allocation = await PortfolioService
            .GetAllocationByTypeAsync(currentUserId);
    }
        // OnAfterRenderAsync : le DOM existe ici → on peut appeler Chart.js
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (lines == null || !lines.Any() || chartsRendered)
            return;

        chartError = null;

        if (lines.Any())
        {
            try
            {
                var chartAvailable = await JS
                    .InvokeAsync<bool>("isChartJsAvailable");
                if (!chartAvailable)
                {
                    chartError =
                        "Chart.js est bloqué ou non chargé. Autorisez le CDN ou utilisez une version locale.";
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                await RenderChartsAsync();
                chartsRendered = true;
            }
            catch (Exception ex)
            {
                chartError =
                    "Impossible de charger les graphiques (Chart.js manquant ou bloqué).";
                Console.WriteLine($"[Portfolio] Charts error: {ex.Message}");
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task RenderChartsAsync()
    {
        // ── Graphique 1 : Doughnut — répartition en % par type ──
        var doughnutLabels = allocation.Keys.ToArray();
        var doughnutValues = allocation.Values.Select(v => (double)v).ToArray();
        var doughnutColors = new[] { "#f0ad4e", "#0d6efd", "#20c997", "#dc3545" };

        await JS.InvokeVoidAsync("renderDoughnutChart",
            "doughnutChart",
            doughnutLabels,
            doughnutValues,
            doughnutColors);

        // ── Graphique 2 : Barres — gain/perte par actif ──
        var barLabels = lines!.Select(l => l.Asset.Symbol).ToArray();
        var barValues = lines!.Select(l =>
        {
            var currentVal = (double)(l.Quantity * l.Asset.CurrentPrice);
            var cost       = (double)(l.Quantity * l.AverageBuyPrice);
            return currentVal - cost;
        }).ToArray();

        await JS.InvokeVoidAsync("renderBarChart",
            "barChart",
            barLabels,
            barValues);
    }
}