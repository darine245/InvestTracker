@page "/login"
@rendermode InteractiveServer 
@using InvestTracker.Services
@using InvestTracker.Services.Interfaces
@using System.ComponentModel.DataAnnotations
@inject AuthState AuthState
@inject IUserService UserService
@inject NavigationManager NavigationManager

<PageTitle>Connexion — InvestTracker</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">

            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-1">🔐 InvestTracker</h4>
                <p class="mb-0 opacity-75">Connectez-vous à votre compte</p>
            </div>

            <div class="card-body p-4">

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">❌ @errorMessage</div>
                }

                <EditForm Model="loginModel"
                          OnValidSubmit="HandleLogin"
                          FormName="login-form">   @* ← OnValidSubmit *@


                    <DataAnnotationsValidator />          @* ← validation active *@
                    <ValidationSummary />


                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Nom d'utilisateur
                        </label>
                        <InputText @bind-Value="loginModel.Username"
                                   class="form-control"
                                   placeholder="manel" />
                        <ValidationMessage For="() => loginModel.Username" />

                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Mot de passe
                        </label>
                        <InputText @bind-Value="loginModel.Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="••••••" />
                        <ValidationMessage For="() => loginModel.Password" />

                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100"
                            disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                           <span> Connexion</span>
                        }
                        else
                        {
                           <span> Se connecter</span>
                        }
                    </button>

                </EditForm>

            </div>

           

        </div>
    </div>
</div>

@code {

    // Modèle avec Data Annotations — le prof les exige
    private class LoginModel
    {
        [Required(ErrorMessage = "Le nom d'utilisateur est obligatoire.")]
        [StringLength(50, MinimumLength = 3,
            ErrorMessage = "Entre 3 et 50 caractères.")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Le mot de passe est obligatoire.")]
        [StringLength(100, MinimumLength = 4,
            ErrorMessage = "Minimum 4 caractères.")]
        public string Password { get; set; } = string.Empty;
    }


    private LoginModel loginModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        if (AuthState.IsAuthenticated)
            NavigationManager.NavigateTo("/");
    }

    // async + interroge la BD via UserService
    private async Task HandleLogin()
    {
        errorMessage = string.Empty;
        isLoading = true;

        try
        {
            var user = await UserService.AuthenticateAsync(
                loginModel.Username.Trim(),
                loginModel.Password);

            if (user != null)
            {
                AuthState.Login(user);
                NavigationManager.NavigateTo("/");
                return;
            }

            errorMessage = "Nom d'utilisateur ou mot de passe incorrect.";
        }
        catch
        {
            errorMessage = "Erreur serveur pendant la connexion.";
        }
        finally
        {
            isLoading = false;
        }
    }

}